{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-dangerous.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify-done.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",

      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git init *)",
      "Bash(git remote *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git tag *)",
      "Bash(git rev-parse *)",
      "Bash(git config --get *)",
      "Bash(git clone *)",

      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(tee *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(ln *)",
      "Bash(tree *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(hostname)",

      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npm list *)",
      "Bash(npm info *)",
      "Bash(npm outdated *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(pip install *)",
      "Bash(pip3 *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(gcc *)",
      "Bash(g++ *)",

      "Bash(docker ps *)",
      "Bash(docker images *)",
      "Bash(docker logs *)",
      "Bash(docker inspect *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker exec *)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(gh *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(ping *)",
      "Bash(dig *)",
      "Bash(nslookup *)",

      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(xargs *)",

      "Bash(kubectl get *)",
      "Bash(kubectl -n * get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl -n * describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl -n * logs *)",
      "Bash(kubectl events *)",
      "Bash(kubectl -n * events *)",
      "Bash(kubectl top *)",
      "Bash(kubectl -n * top *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl version *)",
      "Bash(kubectl config get-contexts*)",
      "Bash(kubectl config view*)",
      "Bash(kubectl auth can-i *)",

      "Bash(kubectl -n * exec * -- temporal * workflow list*)",
      "Bash(kubectl -n * exec * -- temporal * workflow show *)",
      "Bash(kubectl -n * exec * -- temporal * workflow describe *)",
      "Bash(kubectl -n * exec * -- temporal * workflow query *)",
      "Bash(kubectl -n * exec * -- temporal * schedule list*)",
      "Bash(kubectl -n * exec * -- temporal * schedule describe *)",
      "Bash(kubectl -n * exec * -- temporal * activity list*)",

      "Bash(kubectl -n * exec * -- ssh * \"qm list*\")",
      "Bash(kubectl -n * exec * -- ssh * \"qm status *\")",
      "Bash(kubectl -n * exec * -- ssh * \"qm config *\")",
      "Bash(kubectl -n * exec * -- ssh * \"qm listsnapshot *\")",
      "Bash(kubectl -n * exec * -- ssh * \"pvesh get *\")",
      "Bash(kubectl -n * exec * -- ssh * \"pvecm nodes\")",
      "Bash(kubectl -n * exec * -- ssh * \"pvecm status\")",
      "Bash(kubectl -n * exec * -- ssh * \"rbd ls *\")",
      "Bash(kubectl -n * exec * -- ssh * \"rbd info *\")",
      "Bash(kubectl -n * exec * -- ssh * \"systemctl status *\")",
      "Bash(kubectl -n * exec * -- ssh * \"systemctl is-*\")"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  }
}